# uv / pip
pip-log.txt
pip-delete-this-directory.txt
uv.lock        # debate: version or not. Library: ignore. Application: version.
# If this is an application (not a library), REMOVE the line above
# to version the lock file and guarantee reproducible builds.

# Terraform
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
*.tfplan.*

# Override / local-only
*.override.tf
*.override.tf.json
override.tf
override.tf.json

# tfvars may hold sensitive values
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.json.example

# .terraform directories
.terraform/

# Version lock: keep root stacks, ignore submodule copies (recreated by validate)
infra/data-platform/modules/**/.terraform.lock.hcl

# CLI configuration
.terraformrc
terraform.rc

# State and backend
crash.log
crash.*.log

# Generated by bootstrap (recreated on each init)
