site/
.docusaurus/

# Internal-only documents (audit notes, personal roadmap, deltas).
# Glob on AUDITORIA* so every future audit (V3, V4, V5...) is covered
# without editing this file again - listing them one by one left V3/V4
# exposed once and is the kind of drift a glob prevents.
AUDITORIA*.md
ROADMAP_UPGRADE.md
CODE_COMMENTS_GUIDE.md
GUIA_*.md
docs/ROADMAP_UPGRADE.md

# Misc
*.bak
*.tmp
*.temp
.cache/
tmp/
temp/

# Checksums geradas pelo pre-commit
checksums.sha256

# Arquivos compactados de release/backup
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
